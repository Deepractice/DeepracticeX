{
  "name": "@deepracticex/service",
  "version": "1.0.0",
  "description": "Platform-agnostic service framework — DDD, DI, RPC, and repository patterns",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deepracticex/error": "workspace:*",
    "@deepracticex/logger": "workspace:*",
    "@deepracticex/rpc": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.8.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
