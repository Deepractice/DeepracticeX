{
  "name": "@deepracticex/drizzle",
  "version": "0.3.1",
  "description": "Drizzle ORM driver for @deepracticex/sqlite — cross-runtime SQLite (Bun + Node.js 22+)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deepracticex/sqlite": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.38.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
