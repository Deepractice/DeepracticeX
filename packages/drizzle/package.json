{
  "name": "@deepracticex/drizzle",
  "version": "0.2.3",
  "description": "Drizzle ORM driver for @deepracticex/sqlite — cross-runtime SQLite (Bun + Node.js 22+)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deepracticex/sqlite": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.38.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
